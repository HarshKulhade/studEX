# ─────────────────────────────────────────────────
#  Student Super App — Environment Variables
#  Copy this file to `.env` and fill in real values
# ─────────────────────────────────────────────────

# ── Application ──────────────────────────────────
NODE_ENV=development
PORT=5000

# ── MongoDB ───────────────────────────────────────
# Atlas connection string (or local: mongodb://localhost:27017/studentSuperApp)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/studentSuperApp

# ── JWT ──────────────────────────────────────────
# Must be at least 32 random characters
JWT_SECRET=your_super_secret_jwt_key_minimum_32_chars_here
JWT_EXPIRE=7d

# ── Cloudinary ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email / SMTP (Gmail recommended for dev) ─────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
# Use a Gmail App Password (NOT your real password)
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=noreply@studentsuperapp.com

# ── CORS ─────────────────────────────────────────
# Comma-separated allowed origins
CLIENT_URL=http://localhost:3000

# ── Rate Limiting ─────────────────────────────────
# 900000 ms = 15 minutes
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
